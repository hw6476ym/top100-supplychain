if (container) {
  container.innerHTML = companies.map(c => `
    <div style="
      border:1px solid #2a3a55;
      padding:14px;
      margin:10px 0;
      border-radius:10px;
      background:#0f172a;
    ">
      
      <h3 style="margin:0 0 6px 0;">
        ${c.name} <span style="opacity:0.6;">(${c.ticker})</span>
      </h3>

      <p style="margin:4px 0;">
        <b>Segments:</b> ${c.segments.join(", ")}
      </p>

      <p style="margin:4px 0;">
        <b>Resilience Score:</b> 
        <span style="color:${c.resilienceScore > 70 ? '#22c55e' : '#ef4444'};">
          ${c.resilienceScore}
        </span>
      </p>

      <p style="
        margin-top:8px;
        font-size:12px;
        opacity:0.7;
        line-height:1.4;
      ">
        ${c.chain}
      </p>

    </div>
  `).join("");
}
